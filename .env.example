# 빗썸 API 키·계좌 설정 템플릿
# 이 파일을 복사해서 `.env` 로 만들고 실제 값을 채운다:
#   cp .env.example .env
# `.env` 는 .gitignore 로 제외되어 깃에 올라가지 않는다.
#
# ⚠️ 마일스톤 1(백테스트)은 공개 API만 쓰므로 키가 없어도 동작한다.
#    실거래(마일스톤 3) 단계에서만 아래 키가 필요하다.

# 빗썸 API 키 (마이페이지 > API 관리에서 발급)
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=

# 계좌 식별용 메모 (선택, 여러 계좌 구분할 때)
ACCOUNT_LABEL=my-main-account

# ---------------------------------------------------------------------------
# DB 설정
#   DB_ENGINE=sqlite  → 파일 DB (기본, 설정 불필요)
#   DB_ENGINE=mysql   → 로컬 MySQL 사용 (아래 접속정보 채우기)
# 테스트는 항상 SQLite 임시파일을 쓰므로 아래 값과 무관하다.
# ---------------------------------------------------------------------------
DB_ENGINE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=coin
# DB_SQLITE_PATH=coin.db   # DB_ENGINE=sqlite 일 때만 사용
